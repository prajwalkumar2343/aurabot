# OpenRouter API Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: OpenRouter API Key
# Get your API key from: https://openrouter.ai/settings/keys
# This is used for LLM image analysis (vision) and chat responses
# =============================================================================
OPENROUTER_API_KEY=your_openrouter_api_key_here

# =============================================================================
# OpenRouter Base URL (optional - default shown below)
# =============================================================================
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# =============================================================================
# OpenRouter Models (optional - defaults shown below)
# Change these to use different models via OpenRouter
# Find models at: https://openrouter.ai/models
# =============================================================================

# Vision model for analyzing screenshots (must support vision)
OPENROUTER_VISION_MODEL=google/gemini-flash-1.5

# Chat model for conversational responses
OPENROUTER_CHAT_MODEL=anthropic/claude-3.5-sonnet

# Embedding model for text embeddings
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# =============================================================================
# Memory server configuration
# These settings configure the local AuraBot memory API server
# =============================================================================
AURABOT_MEMORY_HOST=localhost
AURABOT_MEMORY_PORT=8000

# Required: Postgres connection string for the memory store
DATABASE_URL=postgresql://user:password@localhost:5432/aurabot

# Optional: protect the local memory API with a bearer token
AURABOT_MEMORY_API_KEY=

# Optional: additional browser origins allowed for CORS, comma-separated
# AURABOT_MEMORY_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:7345
