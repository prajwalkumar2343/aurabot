{
  "name": "aurabot-electron",
  "version": "1.0.0",
  "description": "AuraBot - AI Memory Assistant (Electron Windows Edition)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "dev:win": "set NODE_ENV=development && electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:win:portable": "electron-builder --win portable",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps",
    "compile-go": "cd ../go && go build -o ../electron/build/aurabot-backend.exe main.go"
  },
  "build": {
    "appId": "com.aurabot.app",
    "productName": "AuraBot",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "build/**/*",
      "../config/config.yaml",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "build/aurabot-backend.exe",
        "to": "aurabot-backend.exe"
      },
      {
        "from": "../python",
        "to": "python",
        "filter": [
          "**/*",
          "!**/__pycache__/**"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "publisherName": "AuraBot"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AuraBot"
    },
    "portable": {
      "artifactName": "AuraBot-Portable-${version}.exe"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "sendkeys-js": "^0.0.4"
  }
}
