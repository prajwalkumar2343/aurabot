{
  "id": "finder",
  "app_name": "Finder",
  "category": "file_manager",
  "bundle_ids": ["com.apple.finder"],
  "domains": [],
  "aliases": ["finder", "files", "selected files"],
  "priority": 100,
  "actions": [
    {
      "name": "list_selection",
      "description": "Read the files currently selected in Finder.",
      "intents": ["selected files", "what files are selected", "list selection", "current selection"],
      "preferred_worker": "apple_events",
      "fallback_workers": ["accessibility"],
      "parallel_safe": true,
      "requires_focus": "never",
      "requires_confirmation": false,
      "destructive": false,
      "permissions": ["automation"]
    },
    {
      "name": "move_files",
      "description": "Move selected or specified files to another folder.",
      "intents": ["move files", "organize files", "put files", "move selected", "move these"],
      "preferred_worker": "file_api",
      "fallback_workers": ["apple_events"],
      "parallel_safe": true,
      "requires_focus": "never",
      "requires_confirmation": true,
      "destructive": false,
      "permissions": ["file_access"]
    },
    {
      "name": "delete_files",
      "description": "Delete selected or specified files.",
      "intents": ["delete files", "remove files", "trash files", "delete selected"],
      "preferred_worker": "file_api",
      "fallback_workers": ["apple_events"],
      "parallel_safe": false,
      "requires_focus": "never",
      "requires_confirmation": true,
      "destructive": true,
      "permissions": ["file_access"]
    }
  ]
}
