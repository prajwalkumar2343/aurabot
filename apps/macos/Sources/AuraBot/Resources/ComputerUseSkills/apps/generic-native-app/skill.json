{
  "id": "generic-native-app",
  "app_name": "Generic Native App",
  "category": "native_app",
  "bundle_ids": [],
  "domains": [],
  "aliases": ["app", "window", "native app", "ui"],
  "priority": 1,
  "actions": [
    {
      "name": "inspect_ui",
      "description": "Read the Accessibility tree for an unknown native app.",
      "intents": ["inspect ui", "what is on screen", "find button", "read window", "control app"],
      "preferred_worker": "accessibility",
      "fallback_workers": ["screen_observation"],
      "parallel_safe": true,
      "requires_focus": "never",
      "requires_confirmation": false,
      "destructive": false,
      "permissions": ["accessibility"]
    },
    {
      "name": "press_labeled_control",
      "description": "Press a labeled button or menu item through Accessibility.",
      "intents": ["click button", "press button", "select menu", "choose option"],
      "preferred_worker": "accessibility",
      "fallback_workers": ["foreground_input"],
      "parallel_safe": false,
      "requires_focus": "app_dependent",
      "requires_confirmation": true,
      "destructive": false,
      "permissions": ["accessibility"]
    },
    {
      "name": "set_text_field",
      "description": "Set text in a visible text field through Accessibility.",
      "intents": ["type text", "set text", "fill text", "enter text"],
      "preferred_worker": "accessibility",
      "fallback_workers": ["foreground_input"],
      "parallel_safe": false,
      "requires_focus": "app_dependent",
      "requires_confirmation": true,
      "destructive": false,
      "permissions": ["accessibility"]
    }
  ]
}
