{
  "id": "chrome",
  "app_name": "Google Chrome",
  "category": "browser",
  "bundle_ids": ["com.google.Chrome", "com.microsoft.edgemac", "com.brave.Browser", "company.thebrowser.Browser"],
  "domains": [],
  "aliases": ["chrome", "chromium", "edge", "brave", "arc", "browser", "webpage"],
  "priority": 95,
  "actions": [
    {
      "name": "extract_page_context",
      "description": "Extract current page context through the browser extension or browser automation.",
      "intents": ["current page", "active tab", "this webpage", "summarize this page", "extract page"],
      "preferred_worker": "browser_extension",
      "fallback_workers": ["browser_devtools", "apple_events", "accessibility"],
      "parallel_safe": true,
      "requires_focus": "never",
      "requires_confirmation": false,
      "destructive": false,
      "permissions": ["browser_extension"]
    },
    {
      "name": "fill_form",
      "description": "Fill a web form with user-approved values.",
      "intents": ["fill form", "enter details", "complete form", "submit form"],
      "preferred_worker": "browser_extension",
      "fallback_workers": ["accessibility", "foreground_input"],
      "parallel_safe": false,
      "requires_focus": "app_dependent",
      "requires_confirmation": true,
      "destructive": false,
      "permissions": ["browser_extension", "accessibility"]
    }
  ]
}
