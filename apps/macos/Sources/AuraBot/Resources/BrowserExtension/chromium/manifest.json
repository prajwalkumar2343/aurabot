{
  "manifest_version": 3,
  "name": "AuraBot Browser Context",
  "version": "0.1.0",
  "description": "Sends active page context to the local AuraBot macOS app.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["http://127.0.0.1:7345/*", "http://localhost:7345/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["settings.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "AuraBot Browser Context"
  }
}
