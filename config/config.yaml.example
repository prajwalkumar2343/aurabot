# Screen capture configuration
capture:
  interval_seconds: 30          # How often to capture screen
  quality: 60                   # JPEG quality (1-100) - lower = smaller images, less VRAM
  max_width: 1280               # Resize screenshot max width
  max_height: 720               # Resize screenshot max height
  enabled: true                 # Start capturing immediately

# LLM Configuration (Chat & Text)
llm:
  provider: "lm-studio"         # openai, anthropic, gemini, groq, cerebras, ollama, lm-studio, custom
  base_url: "http://localhost:1234/v1"
  api_key: ""
  model: "local-model"
  max_tokens: 512
  temperature: 0.7

# Vision Configuration (Image Analysis)
vision:
  provider: "lm-studio"
  base_url: "http://localhost:1234/v1"
  api_key: ""
  model: "local-model"

# Embeddings Configuration (Memory)
embeddings:
  provider: "lm-studio"
  base_url: "http://localhost:1234/v1"
  api_key: ""
  model: "local-model"
  dimensions: 768

# Mem0 Configuration
memory:
  api_key: ""                   # Leave empty for local Mem0
  base_url: "http://localhost:8000"  # Mem0 server URL
  user_id: "default_user"
  collection_name: "screen_memories"

# App behavior
app:
  verbose: false                # Enable debug logging
  process_on_capture: true      # Process with LLM on every capture
  memory_window: 10             # Last N memories to include as context
