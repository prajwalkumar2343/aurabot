# Screen capture configuration
capture:
  interval_seconds: 30          # How often to capture screen
  quality: 60                   # Image quality (1-100) - lower = smaller images, less VRAM
  format: webp                  # Image format: webp (smaller, default) or jpeg
  max_width: 1280               # Resize screenshot max width
  max_height: 720               # Resize screenshot max height
  enabled: true                 # Start capturing immediately

# LLM Configuration (Chat & Text)
# Using OpenRouter - set OPENROUTER_API_KEY in your .env file
llm:
  provider: "openrouter"        # openai, anthropic, gemini, groq, cerebras, ollama, openrouter, custom
  base_url: "https://openrouter.ai/api/v1"
  api_key: ""                   # Loaded from OPENROUTER_API_KEY env var
  model: "anthropic/claude-3.5-sonnet"
  max_tokens: 512
  temperature: 0.7

# Vision Configuration (Image Analysis - Screenshot understanding)
# Using OpenRouter - set OPENROUTER_API_KEY in your .env file
vision:
  provider: "openrouter"
  base_url: "https://openrouter.ai/api/v1"
  api_key: ""                   # Loaded from OPENROUTER_API_KEY env var
  model: "google/gemini-flash-1.5"

# Embeddings Configuration (Memory)
# Using OpenRouter - set OPENROUTER_API_KEY in your .env file
embeddings:
  provider: "openrouter"
  base_url: "https://openrouter.ai/api/v1"
  api_key: ""                   # Loaded from OPENROUTER_API_KEY env var
  model: "openai/text-embedding-3-small"
  dimensions: 1536

# Memory API configuration
memory:
  api_key: ""                   # Optional bearer token
  base_url: "http://127.0.0.1:8766"  # Managed local PGlite Memory v2 URL
  user_id: "default_user"
  collection_name: "screen_memories"

# App behavior
app:
  verbose: false                # Enable debug logging
  process_on_capture: true      # Process with LLM on every capture
  memory_window: 10             # Last N memories to include as context
